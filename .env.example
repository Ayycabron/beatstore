# Copier ce fichier en .env et remplir les valeurs

# Dropbox — token d'accès (App Console Dropbox)
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here

# Dossier Dropbox contenant les beats (optionnel, défaut /NEW)
DROPBOX_BEATS_DIR=/NEW

# Port du serveur Express (optionnel, défaut 3000)
PORT=3000
